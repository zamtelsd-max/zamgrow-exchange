# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: https://neon.tech → New Project → Connection String
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/zamgrow?sslmode=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="30d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
CORS_ORIGINS="https://zamtelsd-max.github.io,https://depcxnwq.gensparkclaw.com,http://20.97.114.220:8080"

# ── Africa's Talking (SMS OTP for Zambia) ────────────────────────────────────
# Get from: https://africastalking.com → Create Account → API Key
AT_API_KEY="your-africas-talking-api-key"
AT_USERNAME="your-username"      # use "sandbox" for testing
AT_SENDER_ID="ZAMGROW"           # optional branded sender

# ── DPO Pay / Flutterwave (Mobile Money Payments) ────────────────────────────
# DPO Pay: https://dpogroup.com → Zambia → Airtel Money + MTN MoMo
# OR Flutterwave: https://flutterwave.com → supports Zambia Airtel
PAYMENT_COMPANY_TOKEN="your-dpo-company-token"
PAYMENT_ENV="test"               # "test" or "live"

# ── File uploads (Cloudinary) ─────────────────────────────────────────────────
# Get from: https://cloudinary.com → Free tier → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
