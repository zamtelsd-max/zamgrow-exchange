generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?  @unique
  passwordHash String?
  role         UserRole @default(farmer)
  province     String
  district     String?
  credits      Int      @default(10)
  subscription SubscriptionTier @default(free)
  verified     Boolean  @default(false)
  banned       Boolean  @default(false)
  rating       Float    @default(0)
  totalReviews Int      @default(0)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings      Listing[]
  offersGiven   Offer[]        @relation("OfferBuyer")
  reviewsGiven  Review[]       @relation("ReviewAuthor")
  reviewsGotten Review[]       @relation("ReviewTarget")
  notifications Notification[]
  watchlist     WatchlistItem[]
  transactions  Transaction[]
  subscriptions Subscription[]
  creditsLog    CreditsLog[]
  otpCodes      OtpCode[]
}

model Province {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  capital  String
  districts District[]
}

model District {
  id         Int      @id @default(autoincrement())
  name       String
  province   Province @relation(fields: [provinceId], references: [id])
  provinceId Int
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  emoji    String
  products Product[]
}

model Product {
  id           Int           @id @default(autoincrement())
  name         String
  category     Category      @relation(fields: [categoryId], references: [id])
  categoryId   Int
  listings     Listing[]
  priceHistory PriceHistory[]
  priceAlerts  PriceAlert[]
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        ListingType   @default(sell)
  price       Float
  unit        String
  quantity    Float
  product     Product       @relation(fields: [productId], references: [id])
  productId   Int
  province    String
  district    String?
  seller      User          @relation(fields: [sellerId], references: [id])
  sellerId    String
  status      ListingStatus @default(active)
  views       Int           @default(0)
  isFeatured  Boolean       @default(false)
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  photos    ListingPhoto[]
  offers    Offer[]
  watchedBy WatchlistItem[]
}

model ListingPhoto {
  id        Int     @id @default(autoincrement())
  url       String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  order     Int     @default(0)
}

model Offer {
  id        String      @id @default(cuid())
  listing   Listing     @relation(fields: [listingId], references: [id])
  listingId String
  buyer     User        @relation("OfferBuyer", fields: [buyerId], references: [id])
  buyerId   String
  price     Float
  message   String?
  status    OfferStatus @default(pending)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  authorId   String
  target     User     @relation("ReviewTarget", fields: [targetId], references: [id])
  targetId   String
  rating     Int
  comment    String?
  product    String?
  createdAt  DateTime @default(now())
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  province   String?
  price      Float
  volume     Float?
  recordedAt DateTime @default(now())
}

model PriceAlert {
  id         String   @id @default(cuid())
  userId     String
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  targetPrice Float
  province   String?
  triggered  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  linkTo    String?
  createdAt DateTime         @default(now())
}

model WatchlistItem {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Transaction {
  id          String            @id @default(cuid())
  user        User              @relation(fields: [userId], references: [id])
  userId      String
  type        TransactionType
  amount      Float
  currency    String            @default("ZMW")
  status      TransactionStatus @default(pending)
  reference   String?
  description String?
  createdAt   DateTime          @default(now())
}

model Subscription {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  tier      SubscriptionTier
  startDate DateTime         @default(now())
  endDate   DateTime
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
}

model CreditsLog {
  id          Int             @id @default(autoincrement())
  user        User            @relation(fields: [userId], references: [id])
  userId      String
  amount      Int
  type        CreditsLogType
  description String?
  createdAt   DateTime        @default(now())
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum UserRole {
  farmer
  buyer
  dealer
  admin
}

enum SubscriptionTier {
  free
  basic
  pro
  premium
}

enum ListingType {
  sell
  buy
}

enum ListingStatus {
  active
  sold
  expired
  pending
  rejected
}

enum OfferStatus {
  pending
  accepted
  rejected
  countered
}

enum NotificationType {
  offer
  message
  price_alert
  system
  payment
}

enum TransactionType {
  subscription
  credits_purchase
  listing_fee
  commission
}

enum TransactionStatus {
  pending
  completed
  failed
  refunded
}

enum CreditsLogType {
  earned
  spent
  purchased
  bonus
  expired
}
